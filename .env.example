# Environment Variables Template
# Copy this to .env and fill in your values
# DO NOT commit real secrets to this file

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres is exposed on host port 5433 by docker-compose (internal port 5432)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=gymcoach
POSTGRES_PASSWORD=gymcoach_password
POSTGRES_DB=gymcoach
DATABASE_URL=postgresql://gymcoach:gymcoach_password@localhost:5433/gymcoach

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Bull Queue (uses same Redis instance)
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379

# ── Qdrant Vector DB ──────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# IMPORTANT: Change these to strong random strings before deploying to production
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Internal service-to-service auth secret (used by services when calling each other)
INTERNAL_SERVICE_SECRET=dev_internal_service_secret_change_in_production

# ── Service URLs ──────────────────────────────────────────────────────────────
# These are used by the gateway and inter-service calls (local dev: localhost, Docker: service names)
AUTH_SERVICE_URL=http://localhost:3001
FITNESS_SERVICE_URL=http://localhost:3002
AI_SERVICE_URL=http://localhost:3003
USER_SERVICE_URL=http://localhost:3004
CHAT_SERVICE_URL=http://localhost:3005

# ── Chat Service ──────────────────────────────────────────────────────────────
CHAT_SERVICE_PORT=3005
CHAT_DATABASE_URL=postgresql://gymcoach:gymcoach_password@localhost:5433/gymcoach_chat
# Frontend — Socket.IO connects directly to chat-service (bypasses HTTP gateway)
VITE_CHAT_WS_URL=http://localhost:3005

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported: ollama | openai (any OpenAI-compatible API)
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_MODEL=llama3.2:3b
# Docker containers use host.docker.internal to reach Ollama on the host machine
LLM_BASE_URL=http://localhost:11434

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Use a Gmail App Password (not your regular Gmail password)
# See: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="AI Gym Coach <your_gmail_address@gmail.com>"
SMTP_SECURE=true

# ── OTP Settings ─────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5

# ── n8n Workflow Orchestration ────────────────────────────────────────────────
# n8n runs at port 5678, managed via admin UI at /admin/workflows
N8N_HOST=localhost
N8N_PATH=/
N8N_WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh

# Basic auth protects the n8n Studio UI (change before production)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_this_n8n_password
N8N_LICENSE_ACTIVATION_KEY=

# Public API key — generated inside n8n Studio → Settings → API
# Required for gateway to list workflows via /admin/workflows endpoint
# Leave empty if you don't need workflow listing in admin dashboard
N8N_PUBLIC_API_KEY=
N8N_PUBLIC_API_DISABLED=false

# Gateway env vars for n8n proxy (used in docker-compose, not needed for local-only dev)
N8N_BASE_URL=http://localhost:5678
N8N_EDITOR_BASE_PATH=/admin/workflows/studio

# Smoke test webhook URL — used by POST /admin/workflows/smoke-test
# Import infra/n8n/workflows/smoke-test-ping.json into n8n and activate it first.
# Docker Compose (gateway inside Docker): http://n8n:5678/webhook/gym-smoke-test
# Local dev (gateway outside Docker):     http://localhost:5678/webhook/gym-smoke-test
N8N_SMOKE_TEST_WEBHOOK_URL=

# E2E test webhook URL — used by POST /admin/workflows/full-system-test
# Import and activate 01-05 sub-workflows, then 06-gym-e2e-orchestrator.json.
# Docker Compose (gateway inside Docker): http://n8n:5678/webhook/gym-e2e-run
# Local dev (gateway outside Docker):     http://localhost:5678/webhook/gym-e2e-run
N8N_E2E_WEBHOOK_URL=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Node / Gateway ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
