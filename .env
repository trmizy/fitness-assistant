# Environment Variables Template
# Copy this to .env and fill in your values

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=gymcoach
POSTGRES_PASSWORD=gymcoach_password
POSTGRES_DB=gymcoach

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Qdrant Vector DB
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# JWT Secrets
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Services URLs (for inter-service communication)
API_GATEWAY_URL=http://localhost:3000
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
INBODY_SERVICE_URL=http://localhost:3003
WORKOUT_SERVICE_URL=http://localhost:3004
PLANNING_SERVICE_URL=http://localhost:3005
LLM_SERVICE_URL=http://localhost:3006
NOTIFICATION_SERVICE_URL=http://localhost:3007

# LLM Provider (openai|gemini|claude|ollama)
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_MODEL=llama3.2:3b
LLM_BASE_URL=http://localhost:11434

# Embedding Model
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Node Environment
NODE_ENV=development
PORT=3000

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173

# Bull Queue
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
