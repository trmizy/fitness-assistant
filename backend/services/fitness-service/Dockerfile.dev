FROM node:20-alpine
RUN corepack enable && corepack prepare pnpm@8.15.0 --activate
RUN apk add --no-cache openssl wget

WORKDIR /app

# ── Install dependencies (cached layer) ──────────────────────────────────────
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY backend/shared/package.json                         ./backend/shared/
COPY backend/services/fitness-service/package.json       ./backend/services/fitness-service/
RUN pnpm install --filter @gym-coach/fitness-service

# ── Pre-build @gym-coach/shared ───────────────────────────────────────────────
COPY tsconfig.base.json                                  ./
COPY backend/shared/tsconfig.json                        ./backend/shared/
COPY backend/shared/src                                  ./backend/shared/src
RUN pnpm --filter @gym-coach/shared build

# ── Generate Prisma client ────────────────────────────────────────────────────
COPY backend/services/fitness-service/prisma             ./backend/services/fitness-service/prisma
RUN pnpm --filter @gym-coach/fitness-service db:generate

# ── Copy service config (src/ is bind-mounted at runtime) ─────────────────────
COPY backend/services/fitness-service/tsconfig.json      ./backend/services/fitness-service/

WORKDIR /app/backend/services/fitness-service
EXPOSE 3002

CMD ["sh", "-c", "node_modules/.bin/prisma migrate deploy && pnpm run dev"]
