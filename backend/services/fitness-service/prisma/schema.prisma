generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExerciseType {
  STRENGTH
  CARDIO
  MOBILITY
  STRENGTH_CARDIO
  STRENGTH_MOBILITY
}

enum EquipmentType {
  BODYWEIGHT
  BARBELL
  DUMBBELLS
  KETTLEBELL
  MACHINE
  RESISTANCE_BAND
  CABLE
  MEDICINE_BALL
  FOAM_ROLLER
}

enum BodyPart {
  UPPER_BODY
  LOWER_BODY
  CORE
  FULL_BODY
}

enum MovementType {
  PUSH
  PULL
  HOLD
  STRETCH
}

model Exercise {
  id                    String         @id @default(uuid())
  exerciseName          String         @map("exercise_name")
  typeOfActivity        ExerciseType   @map("type_of_activity")
  typeOfEquipment       EquipmentType  @map("type_of_equipment")
  bodyPart              BodyPart       @map("body_part")
  type                  MovementType
  muscleGroupsActivated String[]       @map("muscle_groups_activated")
  instructions          String
  videoUrl              String?        @map("video_url")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  workoutExercises        WorkoutExercise[]
  workoutProgramExercises WorkoutProgramExercise[]

  @@index([bodyPart, typeOfActivity])
  @@index([typeOfEquipment])
  @@map("exercises")
}

model Workout {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  date        DateTime @default(now())
  duration    Int?     // minutes
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  exercises   WorkoutExercise[]
  schedules   WorkoutSchedule[]

  @@index([userId, date])
  @@map("workouts")
}

model WorkoutExercise {
  id         String   @id @default(uuid())
  workoutId  String   @map("workout_id")
  exerciseId String   @map("exercise_id")
  sets       Int
  reps       Int?
  duration   Int?     // seconds for holds/cardio
  weight     Float?   // kg
  notes      String?
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  workout     Workout      @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise    Exercise     @relation(fields: [exerciseId], references: [id])
  workoutSets WorkoutSet[]

  @@index([workoutId])
  @@index([exerciseId])
  @@map("workout_exercises")
}

model WorkoutSet {
  id                String          @id @default(uuid())
  workoutExerciseId String          @map("workout_exercise_id")
  setNumber         Int             @map("set_number")
  reps              Int?
  weight            Float?          // kg
  rpe               Float?          // Rate of Perceived Exertion (1-10)
  completed         Boolean         @default(false)
  createdAt         DateTime        @default(now()) @map("created_at")

  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([workoutExerciseId])
  @@map("workout_sets")
}

model NutritionLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  date        DateTime @default(now())
  mealType    String   @map("meal_type") // breakfast, lunch, dinner, snack
  foodName    String   @map("food_name")
  calories    Int
  protein     Float?   // grams
  carbs       Float?   // grams
  fats        Float?   // grams
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId, date])
  @@map("nutrition_logs")
}

// 📊 Body Composition Tracking
model BodyMetrics {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  date            DateTime @default(now())
  weight          Float?   // kg
  bodyFat         Float?   @map("body_fat") // percentage
  muscleMass      Float?   @map("muscle_mass") // kg
  bodyWater       Float?   @map("body_water") // percentage
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId, date])
  @@map("body_metrics")
}

// 💪 Workout Program Templates
model WorkoutProgram {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String   // "Muscle Gain", "Cutting", etc.
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  days            WorkoutProgramDay[]

  @@index([userId])
  @@map("workout_programs")
}

// 📅 Individual Days within a Workout Program
model WorkoutProgramDay {
  id              String   @id @default(uuid())
  programId       String   @map("program_id")
  dayNumber       Int      @map("day_number") // 1, 2, 3...
  title           String   // "Chest + Triceps", "Back + Biceps"
  description     String?
  duration        Int?     // minutes
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  program         WorkoutProgram        @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises       WorkoutProgramExercise[]
  schedules       WorkoutSchedule[]

  @@unique([programId, dayNumber])
  @@index([programId])
  @@map("workout_program_days")
}

// 🏋️ Exercises within a Program Day (with prescriptions)
model WorkoutProgramExercise {
  id              String   @id @default(uuid())
  programDayId    String   @map("program_day_id")
  exerciseId      String   @map("exercise_id")
  order           Int      @default(0)
  sets            Int?
  reps            Int?
  weight          Float?   // kg
  duration        Int?     // seconds
  restSeconds     Int?     @map("rest_seconds")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  programDay      WorkoutProgramDay @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  exercise        Exercise          @relation(fields: [exerciseId], references: [id])

  @@index([programDayId])
  @@index([exerciseId])
  @@map("workout_program_exercises")
}

// 📆 Calendar Scheduling (links user to program days on specific dates)
model WorkoutSchedule {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  date            DateTime
  programDayId    String?  @map("program_day_id") // optional: which program day is scheduled
  workoutId       String?  @map("workout_id")     // optional: completed workout
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  programDay      WorkoutProgramDay? @relation(fields: [programDayId], references: [id], onDelete: SetNull)
  workout         Workout?           @relation(fields: [workoutId], references: [id], onDelete: SetNull)

  @@unique([userId, date])
  @@index([userId, date])
  @@index([programDayId])
  @@index([workoutId])
  @@map("workout_schedules")
}
