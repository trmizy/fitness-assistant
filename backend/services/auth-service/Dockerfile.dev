FROM node:20-alpine
RUN corepack enable && corepack prepare pnpm@8.15.0 --activate
RUN apk add --no-cache openssl wget

WORKDIR /app

# ── Install dependencies (cached layer) ──────────────────────────────────────
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY backend/shared/package.json                       ./backend/shared/
COPY backend/services/auth-service/package.json        ./backend/services/auth-service/
RUN pnpm install --filter @gym-coach/auth-service

# ── Pre-build @gym-coach/shared ───────────────────────────────────────────────
COPY tsconfig.base.json                                ./
COPY backend/shared/tsconfig.json                      ./backend/shared/
COPY backend/shared/src                                ./backend/shared/src
RUN pnpm --filter @gym-coach/shared build

# ── Generate Prisma client ────────────────────────────────────────────────────
COPY backend/services/auth-service/prisma              ./backend/services/auth-service/prisma
RUN pnpm --filter @gym-coach/auth-service db:generate

# ── Copy service config (src/ is bind-mounted at runtime) ─────────────────────
COPY backend/services/auth-service/tsconfig.json       ./backend/services/auth-service/

WORKDIR /app/backend/services/auth-service
EXPOSE 3001

# prisma migrate deploy: safe in dev (applies pending migrations)
# tsx watch: hot-reload on any .ts file change inside src/
CMD ["sh", "-c", "node_modules/.bin/prisma migrate deploy && pnpm run dev"]
