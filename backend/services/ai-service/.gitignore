# Environment
.env
.env.local

# Build output
dist/
node_modules/

# Prisma generated client
src/generated/

# ─── Dataset caches (large files — do not commit) ────────────────────────────

# USDA and Open Food Facts API response caches
data/cache/

# Full free-exercise-db download (~800KB, regenerate with: npm run seed:exercises)
# The sample seed (10 exercises) IS committed. The full download is not.
# Uncomment the line below to also exclude the sample:
# data/datasets/free-exercise-db/exercises.json

# Full wger exercise catalog (generated by: npm run import:wger)
data/datasets/wger/exercises.json

# NHANES datasets (large CDC files — must be downloaded manually)
data/datasets/nhanes/*.csv
data/datasets/nhanes/*.XPT
data/datasets/nhanes/*.sas7bdat
# Keep the metadata summary
!data/datasets/nhanes/_meta.json

# Kaggle datasets (downloaded via Kaggle CLI)
data/datasets/kaggle/
