FROM node:20-alpine
RUN corepack enable && corepack prepare pnpm@8.15.0 --activate
RUN apk add --no-cache openssl wget

WORKDIR /app

# ── Install dependencies (cached layer) ──────────────────────────────────────
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY backend/shared/package.json                      ./backend/shared/
COPY backend/services/ai-service/package.json         ./backend/services/ai-service/
RUN pnpm install --filter @gym-coach/ai-service

# ── Pre-build @gym-coach/shared ───────────────────────────────────────────────
COPY tsconfig.base.json                               ./
COPY backend/shared/tsconfig.json                     ./backend/shared/
COPY backend/shared/src                               ./backend/shared/src
RUN pnpm --filter @gym-coach/shared build

# ── Generate Prisma client ────────────────────────────────────────────────────
COPY backend/services/ai-service/prisma               ./backend/services/ai-service/prisma
RUN pnpm --filter @gym-coach/ai-service db:generate

# ── Copy service config (src/ is bind-mounted at runtime) ─────────────────────
COPY backend/services/ai-service/tsconfig.json        ./backend/services/ai-service/

WORKDIR /app/backend/services/ai-service
EXPOSE 3003

CMD ["sh", "-c", "node_modules/.bin/prisma migrate deploy && npx tsx src/ingest.ts --collection=all --check-empty && pnpm run dev"]
