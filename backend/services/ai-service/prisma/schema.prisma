generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id                        String    @id @default(uuid())
  userId                    String?   @map("user_id")
  question                  String
  answer                    String
  modelUsed                 String    @map("model_used")
  responseTime              Float     @map("response_time")
  relevance                 String?
  relevanceExplanation      String?   @map("relevance_explanation")
  promptTokens              Int       @map("prompt_tokens")
  completionTokens          Int       @map("completion_tokens")
  totalTokens               Int       @map("total_tokens")
  cost                      Float     @default(0)
  feedback                  Int?
  feedbackTimestamp         DateTime? @map("feedback_timestamp")
  // ── Observability fields ────────────────────────────────────────────────────
  traceId                   String?   @map("trace_id")
  usedFallback              Boolean   @default(false) @map("used_fallback")
  usedDeterministicFallback Boolean   @default(false) @map("used_deterministic_fallback")
  responseLanguage          String?   @map("response_language")
  routeIntent               String?   @map("route_intent")
  warningCount              Int       @default(0) @map("warning_count")
  createdAt                 DateTime  @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([routeIntent])
  @@index([usedFallback])
  @@map("conversations")
}

enum PlanStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model WorkoutPlan {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  name        String
  description String?
  goal        String
  duration    Int
  daysPerWeek Int        @map("days_per_week")
  /// Structured JSON matching PlanContentSchema once COMPLETED; empty object while QUEUED/PROCESSING
  plan        Json
  status      PlanStatus @default(QUEUED)
  version     Int        @default(1)
  /// BullMQ job ID — used for polling via GET /plans/job/:jobId
  jobId       String?    @map("job_id")
  failReason  String?    @map("fail_reason")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([userId])
  @@index([jobId])
  @@index([userId, status])
  @@map("workout_plans")
}
