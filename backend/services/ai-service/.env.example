NODE_ENV=development
PORT=3003
DATABASE_URL="postgresql://gymcoach:gymcoach_password@localhost:5433/gym_coach_ai?schema=public"
REDIS_HOST=localhost
REDIS_PORT=6379
QDRANT_HOST=localhost
QDRANT_PORT=6333
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text

# ─── Dataset Providers ────────────────────────────────────────────────────────

# USDA FoodData Central — AUTHORITATIVE source for nutrition macros.
# Required for live nutrition responses. Get a free key at:
# https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your_usda_api_key_here

# Open Food Facts — supplementary enrichment (branded foods, barcodes).
# Public API — no key required. Set to false to disable.
OPEN_FOOD_FACTS_ENABLED=true

# wger — exercise catalog (AGPLv3). Public API, no key required.
# Override WGER_BASE_URL if you self-host wger.
WGER_ENABLED=true
WGER_BASE_URL=https://wger.de/api/v2

# free-exercise-db — local exercise seed (MIT). Run `npm run seed:exercises` first.
FREE_EXERCISE_DB_ENABLED=true

# ExerciseDB — optional large exercise catalog.
# DISABLED by default — requires RapidAPI key AND license review.
# See DATASETS.md before enabling.
EXERCISEDB_ENABLED=false
EXERCISEDB_API_KEY=

# NHANES (CDC) — analytics/demo ONLY. Never used for live nutrition truth.
# Disabled by default. Requires manual file download.
NHANES_ENABLED=false

# Kaggle fitness datasets — analytics/demo ONLY.
# Disabled by default. License varies per dataset.
KAGGLE_DATASETS_ENABLED=false
